{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "apphosting": {
    "backendId": "kumara-community",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      ".next",
      "out",
      "dist",
      "coverage",
      "dev-server.log",
      "dev-server.err.log",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "functions"
    ]
  }
}
