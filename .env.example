KORIN_SESSION_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_APP_URL=https://kumara--kumara-june2026.us-central1.hosted.app

# Firebase Web SDK config. Required for client-side Firebase features.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=kumara-june2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=kumara-june2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=kumara-june2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_web_app_id
NEXT_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_SITE_KEY=your_firebase_app_check_recaptcha_site_key

# Kumara currently sends sign-up verification codes through SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address
SMTP_PASS=your_gmail_app_password
SMTP_FROM=Korin <no-reply@korin.nz>

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
