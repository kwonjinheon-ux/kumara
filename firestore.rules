rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validUser(data) {
      return data.uid is string
        && data.uid == request.auth.uid
        && data.email is string
        && data.email.size() <= 254
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 60
        && data.role == "user"
        && data.emailVerified is bool
        && (!("photoURL" in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048));
    }

    function validPost(data) {
      return data.authorId is string
        && data.authorId == request.auth.uid
        && data.title is string
        && data.title.size() >= 1
        && data.title.size() <= 120
        && data.content is string
        && data.content.size() <= 12000
        && data.status is string
        && data.status.size() <= 40
        && data.imageUrls is list
        && data.imageUrls.size() <= 12
        && (!("price" in data) || data.price == null || (data.price is number && data.price >= 0))
        && (!("category" in data) || data.category is string)
        && (!("location" in data) || data.location is string);
    }

    function validComment(data) {
      return data.authorId is string
        && data.authorId == request.auth.uid
        && data.content is string
        && data.content.size() >= 1
        && data.content.size() <= 2000
        && (!("parentId" in data) || data.parentId == null || data.parentId is string);
    }

    function onlyCounterFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "bookmarkCount", "commentCount", "upvoteCount", "downvoteCount", "likeCount"
      ]);
    }

    match /users/{userId} {
      allow read, create: if isOwner(userId) && validUser(request.resource.data);
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && validUser(request.resource.data);
      allow delete: if false;

      match /bookmarks/{postId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasOnly(["postId", "createdAt"]);
      }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn() && validPost(request.resource.data);
      allow update: if (
          signedIn()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && validPost(request.resource.data)
        ) || (signedIn() && onlyCounterFields());
      allow delete: if signedIn() && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn() && validComment(request.resource.data);
        allow update: if signedIn()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && validComment(request.resource.data);
        allow delete: if signedIn() && resource.data.authorId == request.auth.uid;
      }

      match /likes/{userId} {
        allow read: if true;
        allow delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasOnly(["uid", "vote", "updatedAt"])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.vote in ["up", "down"];
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
