{
  "name": "korin",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "next dev --webpack --hostname 0.0.0.0",
    "dev:turbo": "next dev --turbopack --hostname 0.0.0.0",
    "build": "next build",
    "deploy": "npx -y firebase-tools@latest deploy",
    "deploy:apphosting": "npx -y firebase-tools@latest deploy --only apphosting",
    "emulate:hosting": "npx -y firebase-tools@latest emulators:start --only hosting",
    "migrate:firebase": "node scripts/migrate-local-data-to-firestore.js",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.7",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
